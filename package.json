{
  "name": "tech-interview-mastery",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "build": "vite build",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply tech-interview-mastery-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply tech-interview-mastery-db --remote",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --deny-warnings",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "check": "pnpm run cf-typegen && pnpm run typecheck && pnpm run lint && pnpm run format:check && pnpm run test"
  },
  "dependencies": {
    "hono": "^4.12.27"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.17.0",
    "@types/node": "^26.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "packageManager": "pnpm@10.20.0"
}
